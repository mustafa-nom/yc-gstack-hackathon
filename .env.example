ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...
OPENAI_API_KEY=sk-...

# Hog AI — either Bearer token (single key) OR access+secret pair
# Bearer style:   HOG_API_KEY=hog_live_xxxx
# Access+secret:  HOG_API_KEY=ak_xxxx + HOG_SECRET=sk_xxxx
HOG_API_KEY=ak_...
HOG_SECRET=sk_...
HOG_PROJECT_ID=

# Set HOG_MOCK=1 to skip the real Hog API (uses local fixture data instead).
# Useful when Hog credits are exhausted or you want a fast offline demo.
HOG_MOCK=

BROWSER_USE_API_KEY=

# Flip these to actually invoke teammate's pipelines (otherwise mocked).
RUN_REAL_DESIGN_PIPELINE=
RUN_REAL_TIKTOK_PUSH=
